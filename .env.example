# Redis
# Password for the Redis instance. Change this before starting the stack.
REDIS_PASSWORD=changeme

# Set to the Docker service name when running in compose, localhost otherwise.
REDIS_HOST=redis
REDIS_PORT=6379

# API service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# Worker (no SERVICE_PORT needed, worker is not a server)

# Frontend
# URL the frontend container uses to reach the API.
# Use the Docker service name, not localhost.
API_URL=http://api:8000

# Set to false in production
RELOAD=false
